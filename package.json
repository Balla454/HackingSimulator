{
  "name": "hacking-simulator",
  "version": "1.0.0",
  "private": true,
  "description": "Hacking Simulator - An interactive cybersecurity training game",
  "main": "dist-electron/main.js",
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "vite build && electron-builder --publish=never",
    "dist:linux-x64": "vite build && electron-builder --linux --x64",
    "dist:linux-arm64": "vite build && electron-builder --linux --arm64",
    "dist:linux-all": "vite build && electron-builder --linux --x64 --arm64",
    "dist:win-x64": "vite build && electron-builder --win --x64",
    "dist:win-arm64": "vite build && electron-builder --win --arm64",
    "dist:win-all": "vite build && electron-builder --win --x64 --arm64",
    "dist:mac-x64": "vite build && electron-builder --mac --x64",
    "dist:mac-arm64": "vite build && electron-builder --mac --arm64",
    "dist:mac-universal": "vite build && electron-builder --mac --universal",
    "dist:all": "vite build && electron-builder -mwl --x64 --arm64"
  },
  "build": {
    "appId": "com.hackingsimulator.app",
    "productName": "Hacking Simulator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "mac": {
      "icon": "public/icon.icns",
      "category": "public.app-category.games",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "public/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Game"
    }
  }
}
